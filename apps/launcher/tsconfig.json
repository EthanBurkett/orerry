{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@orrery/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"]
    },
    // svelte-check / svelte plugin handles .svelte files;
    // tsc itself only checks .ts files (types: [] avoids pulling in node types
    // that would conflict with the browser lib above).
    "types": []
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "src-tauri"]
}
