# Normalize line endings — LF in the repo, regardless of OS checkout.
* text=auto eol=lf

# Windows batch/cmd must stay CRLF (e.g. Gradle wrapper gradlew.bat).
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.jar binary
